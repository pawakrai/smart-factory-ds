# =============================================================================
# Local-test mode (use with: --profile local)
#   docker compose --env-file .env.local --profile local up -d
#
# Backend talks to the compose 'db' service over the docker network.
# =============================================================================

# Backend connection to the in-compose Postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/furnaceflow

# Browser-facing origins allowed by FastAPI CORS
CORS_ORIGINS=http://localhost

ENV=development

# --- Postgres container ('db' service) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=furnaceflow
POSTGRES_HOST_PORT=5432

# Host port for the Nginx frontend
FRONTEND_PORT=80
