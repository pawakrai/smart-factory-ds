# =============================================================================
# Deploy mode (no compose profile -- 'db' service is NOT started)
#   docker compose --env-file .env.deploy up -d
#
# Backend talks to the existing on-prem PostgreSQL on the LAN.
# The target database must already exist (create via pgAdmin4 if needed):
#     CREATE DATABASE furnaceflow OWNER postgres;
# =============================================================================

# Existing on-prem Postgres
# NOTE: password "PGP@ss!" must be URL-encoded -- '@' = %40, '!' = %21
DATABASE_URL=postgresql+psycopg2://postgres:PGP%40ss%21@192.168.125.10:5432/furnaceflow

# Browser-facing origins allowed by FastAPI CORS
# Replace <deploy-host-ip> with the public IP/hostname users will hit
CORS_ORIGINS=http://localhost,http://<deploy-host-ip>

ENV=production

# Host port for the Nginx frontend
FRONTEND_PORT=80

# POSTGRES_* vars below are unused in deploy mode (db service not started),
# kept here only so a single .env shape works for both modes if desired.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=furnaceflow
POSTGRES_HOST_PORT=5432
